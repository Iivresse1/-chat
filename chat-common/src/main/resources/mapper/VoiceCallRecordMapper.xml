<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.chat.common.mapper.VoiceCallRecordMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.chat.common.entity.VoiceCallRecord">
        <id column="id" property="id" />
        <result column="caller_id" property="callerId" />
        <result column="callee_id" property="calleeId" />
        <result column="call_type" property="callType" />
        <result column="group_id" property="groupId" />
        <result column="status" property="status" />
        <result column="start_time" property="startTime" />
        <result column="end_time" property="endTime" />
        <result column="duration" property="duration" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, caller_id, callee_id, call_type, group_id, status, start_time, end_time, duration
    </sql>

</mapper>
