<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.chat.common.mapper.GroupInfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.chat.common.entity.GroupInfo">
        <id column="id" property="id" />
        <result column="group_name" property="groupName" />
        <result column="announcement" property="announcement" />
        <result column="owner_id" property="ownerId" />
        <result column="max_members" property="maxMembers" />
        <result column="member_count" property="memberCount" />
        <result column="create_time" property="createTime" />
        <result column="status" property="status" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, group_name, announcement, owner_id, max_members, member_count, create_time, status
    </sql>

</mapper>
