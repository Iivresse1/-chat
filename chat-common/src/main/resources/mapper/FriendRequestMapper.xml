<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.chat.common.mapper.FriendRequestMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.chat.common.entity.FriendRequest">
        <id column="id" property="id" />
        <result column="send_user" property="sendUser" />
        <result column="receive_user" property="receiveUser" />
        <result column="message" property="message" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="handle_time" property="handleTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, send_user, receive_user, message, status, create_time, handle_time
    </sql>

</mapper>
